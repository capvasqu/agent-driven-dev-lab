# Example environment for the task / Kanban manager.
# Copy to `.env` and adjust. NEVER put real secrets in this file — it is committed.
# `.env` itself is gitignored.

# HTTP server (Stage 2 REST API)
PORT=3000
HOST=127.0.0.1

# SQLite database location (shared by the REST API and the task-mcp server)
DB_PATH=./data/tasks.db
